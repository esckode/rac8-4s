{
  "name": "@tournament/api",
  "version": "1.0.0",
  "description": "Lambda API endpoints",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "dev:fresh": "rm -f ../../db/tournament.db && npm run dev",
    "seed": "npm run seed:accounts && npm run seed:tournaments",
    "seed:accounts": "tsx scripts/seed-test-accounts.ts",
    "seed:tournaments": "tsx scripts/seed-tournaments.ts",
    "dev:worker": "tsx watch src/worker-entrypoint.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/aws-sdk": "^0.6.0",
    "@anthropic-ai/sdk": "^0.111.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "zod": "^4.4.3"
  }
}
