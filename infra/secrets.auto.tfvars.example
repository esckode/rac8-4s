# Copy to infra/secrets.auto.tfvars (git-ignored) and set your real values.
# tofu auto-loads *.auto.tfvars, so no apply-command change is needed.
# These values are PII/secret and must NOT be committed.

# Real inbox used as the SES sender. In sandbox, SES emails a verification link
# here; it must be an address you can receive at.
email_from_address = "you@example.com"
