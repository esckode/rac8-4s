{
  "name": "tournament-app",
  "version": "1.0.0",
  "description": "Tournament management webapp for racket sports",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core-logic",
    "packages/api",
    "packages/worker",
    "packages/frontend",
    "shared"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "react-window": "^2.2.7",
    "reconnecting-eventsource": "^1.6.5"
