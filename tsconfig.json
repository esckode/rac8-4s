{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["packages/core-logic/src/*"],
      "@api/*": ["packages/api/src/*"],
      "@worker/*": ["packages/worker/src/*"],
      "@frontend/*": ["packages/frontend/src/*"],
      "@shared/*": ["shared/src/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "shared/**/*.ts",
    "db/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/node_modules",
    "**/dist",
    "**/__tests__",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
