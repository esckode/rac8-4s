{
  "env": {
    "node": true,
    "browser": true,
    "es2020": true,
    "jest": true
  },
  "globals": {
    "React": "readonly"
  },
  "extends": [
    "eslint:recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint",
    "security",
    "react-hooks"
  ],
  "rules": {
    "security/detect-object-injection": "off",
    "security/detect-non-literal-regexp": "warn",
    "security/detect-unsafe-regex": "error",
    "security/detect-buffer-noassert": "error",
    "security/detect-child-process": "warn",
    "security/detect-disable-mustache-escape": "error",
    "security/detect-no-csrf-before-method-override": "error",
    "security/detect-non-literal-fs-filename": "warn",
    "security/detect-non-literal-require": "warn",
    "@typescript-eslint/explicit-function-return-types": "off",
    "@typescript-eslint/explicit-member-accessibility": "off",
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-with": "error",
    "no-unused-vars": "off"
  },
  "overrides": [
    {
      "files": [
        "**/__tests__/**/*.ts",
        "**/*.spec.ts",
        "**/*.test.ts"
      ],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unused-vars": "off",
        "no-unused-vars": "off",
        "no-undef": "off"
      }
    },
    {
      "files": [
        "**/*.ts",
        "**/*.tsx"
      ],
      "rules": {
        "no-undef": "off"
      }
    },
    {
      "files": [
        "packages/frontend/src/**/*.ts",
        "packages/frontend/src/**/*.tsx"
      ],
      "rules": {
        "no-restricted-syntax": ["error",
          { "selector": "Literal[value=/#([0-9a-fA-F]{3}){1,2}/]", "message": "Use a color token from tokens.css (e.g. text-[--ink-900]); raw color literals are banned." },
          { "selector": "Literal[value=/rgba?\\(/]", "message": "Use a color token from tokens.css (e.g. text-[--ink-900]); raw color literals are banned." },
          { "selector": "Literal[value=/hsla?\\(/]", "message": "Use a color token from tokens.css (e.g. text-[--ink-900]); raw color literals are banned." },
          { "selector": "TemplateElement[value.raw=/#([0-9a-fA-F]{3}){1,2}/]", "message": "Use a color token from tokens.css (e.g. text-[--ink-900]); raw color literals are banned." },
          { "selector": "TemplateElement[value.raw=/rgba?\\(/]", "message": "Use a color token from tokens.css (e.g. text-[--ink-900]); raw color literals are banned." },
          { "selector": "TemplateElement[value.raw=/hsla?\\(/]", "message": "Use a color token from tokens.css (e.g. text-[--ink-900]); raw color literals are banned." }
        ]
      }
    },
    {
      "files": [
        "packages/frontend/src/components/shared/Logo.tsx",
        "packages/frontend/src/components/shared/LogoMark.tsx",
        "packages/frontend/src/components/shared/__tests__/Logo.spec.tsx",
        "packages/frontend/src/styles/tokens.css",
        "packages/frontend/src/pages/DesignSpec.tsx",
        "packages/frontend/src/__tests__/lint/eslint-config.spec.ts"
      ],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
  ]
}
