# PostgreSQL Database Configuration
# Required for the application to connect to the PostgreSQL database

# Full PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://tournament_user:tournament_pass@localhost:5432/tournament_app

# Server Configuration
# Port the API server listens on
PORT=3001

# Environment
# Options: development, production, test
NODE_ENV=development

# Logging
# Options: debug, info, warn, error
LOG_LEVEL=debug

# JWT Configuration (for organizer authentication)
# Secret key for signing JWT tokens - use strong random value in production
JWT_SECRET=your-secret-key-change-in-production

# Magic Link Configuration
# TTL for magic link tokens in seconds (24 hours default)
MAGIC_LINK_TTL_SECONDS=86400

# Session Configuration
# TTL for session tokens in seconds (24 hours default)
SESSION_TTL_SECONDS=86400

# Rate Limiting
# Maximum failed login attempts before rate limit kicks in
MAX_LOGIN_ATTEMPTS=5
# Rate limit window in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# Distributed Mode (Redis + BullMQ)
# Requires the `redis` service from docker-compose.yml to be running
REDIS_URL=redis://localhost:6379
SSE_BUS=redis
JOB_QUEUE=bullmq
TOKEN_STORE=redis

# Email Configuration (optional - for password reset emails)
# Email service provider: 'mock', 'sendgrid', 'aws-ses'
EMAIL_SERVICE=mock
# From email address for emails sent by application
EMAIL_FROM_ADDRESS=noreply@tournament-app.local

# AWS SES Configuration (if using AWS SES for emails)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key

# SendGrid Configuration (if using SendGrid for emails)
# SENDGRID_API_KEY=your-sendgrid-key
